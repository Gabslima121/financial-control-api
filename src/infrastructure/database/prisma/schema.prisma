generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TransactionType {
  income
  expense
}

enum TransactionStatus {
  pending
  paid
  cancelled
}

enum PaymentMethod {
  credit_card
  debit_card
  pix
  bank_transfer
  cash
  other
}

enum RecurrenceFrequency {
  monthly
}

model User {
  id        String   @id @default(uuid()) @db.Uuid
  name      String   @db.VarChar(255)
  document  String   @unique @db.VarChar(14)
  email     String   @unique @db.VarChar(255)
  password  String   @db.VarChar(255)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  accounts Account[]
}

model Account {
  id             String   @id @default(uuid()) @db.Uuid
  userId         String   @db.Uuid
  name           String   @db.VarChar(100)
  bankName       String?  @db.VarChar(100)
  initialBalance Decimal  @db.Decimal(15, 2)
  createdAt      DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  bankStatements BankStatementTransaction[]
  transactions   FinancialTransaction[]

  @@index([userId])
}

model BankStatementTransaction {
  id          String   @id @default(uuid()) @db.Uuid
  accountId   String   @db.Uuid
  fitId       String   @db.VarChar(100) // ID único do OFX
  amount      Decimal  @db.Decimal(15, 2) // já vem positivo ou negativo
  postedAt    DateTime // data real do banco
  description String?  @db.Text
  rawType     String?  @db.VarChar(50) // CREDIT / DEBIT
  createdAt   DateTime @default(now())

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  financialTransaction FinancialTransaction?

  @@unique([accountId, fitId]) // impede duplicação de OFX
  @@index([accountId, postedAt])
}

model FinancialTransaction {
  id            String            @id @default(uuid()) @db.Uuid
  accountId     String            @db.Uuid
  type          TransactionType
  status        TransactionStatus @default(pending)
  amount        Decimal           @db.Decimal(15, 2)
  description   String?           @db.Text
  paymentMethod PaymentMethod?
  dueDate       DateTime?
  paidAt        DateTime?
  installments  Int               @default(1)
  installment   Int               @default(1)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  recurrenceGroupId    String?              @db.Uuid
  recurrenceFrequency  RecurrenceFrequency?
  recurrenceInterval   Int?
  recurrenceDayOfMonth Int?

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  bankStatementId String?                   @unique @db.Uuid
  bankStatement   BankStatementTransaction? @relation(fields: [bankStatementId], references: [id])

  @@unique([recurrenceGroupId, dueDate])
  @@index([accountId, paidAt])
  @@index([status])
  @@index([recurrenceGroupId])
}

model Person {
  id            String         @id @default(uuid()) @db.Uuid
  name          String         @db.VarChar(255)
  email         String         @unique @db.VarChar(255)
  personIncomes PersonIncome[]
}

model PersonIncome {
  id        String              @id @default(uuid()) @db.Uuid
  personId  String              @db.Uuid
  amount    Decimal             @db.Decimal(15, 2)
  frequency RecurrenceFrequency
  createdAt DateTime            @default(now())

  person Person @relation(fields: [personId], references: [id], onDelete: Cascade)

  @@unique([personId])
}
